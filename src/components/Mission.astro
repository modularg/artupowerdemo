---
const stats = [
  { num: '50%', descEn: 'diesel reduction potential',     descLv: 'dīzeļa samazināšanas potenciāls' },
  { num: '18L',  descEn: 'max engine size',               descLv: 'maks. motora tilpums' },
  { num: '4',    descEn: 'alt. fuel types supported',     descLv: 'atbalstīti alt. degvielas veidi' },
  { num: '2005', descEn: 'years of Bonomi engineering',   descLv: 'Bonomi inženiermākslas gadi' },
];
---
<section id="mission" class="mission-section">
  <div class="section-inner">
    <div class="mission-grid">

      <!-- Left: text block -->
      <div class="mission-text">
        <div class="reveal">
          <span class="section-tag" data-en="Our Mission" data-lv="Mūsu Misija">Our Mission</span>
          <h2
            class="section-title"
            data-en="Working Together for a Green, Competitive and Inclusive World"
            data-lv="Kopā strādājam zaļākai, konkurētspējīgākai un iekļaujošākai pasaulei"
          >
            Working Together for a Green, Competitive and Inclusive World
          </h2>
          <div class="underline-accent"></div>
          <p
            class="section-lead"
            data-en="ABLabs Ltd is a knowledge-intensive cleantech start-up developing alternative solutions for low-emission mobility. Founded in Jūrmala, Latvia, we bring decades of engineering expertise to one of transport's hardest decarbonisation challenges."
            data-lv="SIA ABLabs ir uz zināšanām balstīts tīro tehnoloģiju starts, kas izstrādā alternatīvus risinājumus zemu emisiju mobilitātei. Dibināts Jūrmalā, Latvijā, mēs pielietojam desmitgadēm ilgu inženiermākslu vienā no transporta smagākajām dekarbonizācijas problēmām."
          >
            ABLabs Ltd is a knowledge-intensive cleantech start-up developing alternative solutions for low-emission mobility. Founded in Jūrmala, Latvia, we bring decades of engineering expertise to one of transport's hardest decarbonisation challenges.
          </p>

          <blockquote class="mission-quote">
            <span
              data-en="&ldquo;Our technology proves that the existing diesel fleet can be part of the green transition — not just replaced by it.&rdquo;"
              data-lv="&ldquo;Mūsu tehnoloģija pierāda, ka esošā dīzeļa autoparka var būt daļa no zaļās pārejas — nevis tikai tikt aizstāta ar to.&rdquo;"
            >
              &ldquo;Our technology proves that the existing diesel fleet can be part of the green transition — not just replaced by it.&rdquo;
            </span>
          </blockquote>
        </div>

        <!-- Stats row -->
        <div class="stats-row">
          {stats.map((s, i) => (
            <div class={`stat-item reveal reveal-delay-${i + 1}`}>
              <div class="stat-num">{s.num}</div>
              <div class="stat-desc" data-en={s.descEn} data-lv={s.descLv}>{s.descEn}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: video -->
      <div class="video-col reveal reveal-right reveal-delay-1">
        <div class="video-frame">
          <div class="video-glow" aria-hidden="true"></div>
          <video controls muted loop playsinline preload="metadata" aria-label="ArtuPower technology overview video">
            <source
              src="https://www.artupower.eu/wp-content/uploads/ArtuPower-Video-3-LogoSakums-Captions-720p.mp4"
              type="video/mp4"
            />
          </video>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.mission-section { background: var(--surface-2); }

.mission-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}

/* ── Quote ── */
.mission-quote {
  background: var(--surface-glass);
  border: 1px solid var(--border);
  border-left: 3px solid var(--blue2);
  padding: 20px 24px;
  border-radius: 0 var(--r-md) var(--r-md) 0;
  font-style: italic;
  color: var(--text-2);
  font-size: 1rem;
  line-height: 1.75;
  margin-bottom: 36px;
}

/* ── Stats row ── */
.stats-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.stat-item {
  background: var(--surface-glass);
  border: 1px solid var(--border);
  border-radius: var(--r-md);
  padding: 16px;
  text-align: center;
  transition: border-color var(--t-base), transform var(--t-base) var(--ease-out);
}
.stat-item:hover { border-color: var(--border-blue); transform: translateY(-3px); }

.stat-num {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.7rem; font-weight: 700;
  background: var(--grad-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1; margin-bottom: 6px;
}
.stat-desc {
  font-size: 0.74rem; color: var(--text-3);
  font-weight: 500; line-height: 1.35;
}

/* ── Video ── */
.video-col { position: relative; }
.video-frame {
  position: relative;
  border-radius: var(--r-xl);
  overflow: hidden;
  border: 1px solid var(--border);
  box-shadow: var(--shadow-lg);
}
.video-frame video { width: 100%; display: block; }
.video-glow {
  position: absolute; inset: -2px;
  border-radius: inherit;
  background: var(--grad-hero);
  opacity: 0.2;
  z-index: -1;
  filter: blur(20px);
}

/* ── Responsive ── */
@media (max-width: 960px) {
  .mission-grid { grid-template-columns: 1fr; gap: 44px; }
  .stats-row { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 500px) {
  .stats-row { grid-template-columns: repeat(2, 1fr); gap: 10px; }
}
</style>
