---
const cards = [
  {
    img:     'https://www.artupower.eu/wp-content/uploads/2022/06/service-1.jpg',
    icon:    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>`,
    accentColor: 'rgba(9,159,220,0.12)',
    iconColor: 'var(--blue2)',
    titleEn: 'Gas-Diesel Integration',
    titleLv: 'Gāzes-Dīzeļa Integrācija',
    textEn:  'Alkane gas (LPG, CNG, BioLPG, BioCNG) is mixed with water vapour and introduced into the diesel engine intake. The blend is calibrated by the ArtuPower ECU in real time.',
    textLv:  'Alkāna gāze (LPG, CNG, BioLPG, BioCNG) tiek sajaukta ar ūdens tvaiku un ievadīta dīzeļdzinēja ieplūdē. Sajaukumu reāllaikā kalibrē ArtuPower ECU.',
  },
  {
    img:     'https://www.artupower.eu/wp-content/uploads/2022/06/service-2.jpg',
    icon:    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
    accentColor: 'rgba(58,172,93,0.12)',
    iconColor: 'var(--green2)',
    titleEn: 'Combustion Optimisation',
    titleLv: 'Sadegšanas Optimizācija',
    textEn:  'Water vapour acts as a catalyst, preventing engine knock and stabilising compression temperatures. The result is increased piston pressure, improved torque, and up to 10% efficiency gain.',
    textLv:  'Ūdens tvaiks darbojas kā katalizators, novēršot dzinēja klauvēšanu un stabilizējot saspiešanas temperatūras. Rezultāts — palielināts virzuļa spiediens, uzlabots griezuma moments un līdz 10% efektivitātes pieaugums.',
  },
  {
    img:     'https://www.artupower.eu/wp-content/uploads/2022/06/service-3.jpg',
    icon:    `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    accentColor: 'rgba(255,165,0,0.1)',
    iconColor: '#ffa500',
    titleEn: 'Safe Failsafe Design',
    titleLv: 'Drošs Rezerves Dizains',
    textEn:  'If the ArtuPower system detects any malfunction, the vehicle automatically reverts to diesel-only operation. Full monitoring and control via a dedicated mobile app.',
    textLv:  'Ja ArtuPower sistēma atklāj kādu darbtraucējumu, transportlīdzeklis automātiski pārslēdzas uz tikai dīzeļa darbību. Pilna uzraudzība un vadība caur īpašu mobilo lietotni.',
  },
];
---
<section id="technology">
  <div class="section-inner">
    <div class="section-header reveal">
      <span class="section-tag" data-en="How It Works" data-lv="Kā tas darbojas">How It Works</span>
      <h2 class="section-title" data-en="The ArtuPower Technology" data-lv="ArtuPower Tehnoloģija">The ArtuPower Technology</h2>
      <div class="underline-accent"></div>
      <p
        class="section-lead"
        data-en="Our patented H₂O-CH fuel delivery system integrates alkane gas and water vapour into the intake manifold, harmonising combustion and delivering measurable gains in efficiency, torque, and emissions."
        data-lv="Mūsu patentētā H₂O-CH degvielas padeves sistēma integrē alkāna gāzi un ūdens tvaiku ieplūdes kolektorā, harmonizējot sadegšanu un nodrošinot izmērāmus ieguvumus efektivitātē, griezuma momentā un emisijās."
      >
        Our patented H₂O-CH fuel delivery system integrates alkane gas and water vapour into the intake manifold, harmonising combustion and delivering measurable gains in efficiency, torque, and emissions.
      </p>
    </div>

    <div class="tech-grid">
      {cards.map((c, i) => (
        <div class={`tech-card reveal reveal-delay-${i + 1}`}>
          <div class="card-img-wrap">
            <img src={c.img} alt={c.titleEn} loading="lazy" width="400" height="220" />
            <div class="card-img-overlay"></div>
          </div>
          <div class="tech-card-body">
            <div class="card-icon-wrap" style={`background:${c.accentColor}; color:${c.iconColor};`}>
              <Fragment set:html={c.icon} />
            </div>
            <h3 class="tech-card-title" data-en={c.titleEn} data-lv={c.titleLv}>{c.titleEn}</h3>
            <p  class="tech-card-text"  data-en={c.textEn}  data-lv={c.textLv}>{c.textEn}</p>
          </div>
          <div class="card-border-glow" style={`--glow: ${c.iconColor};`}></div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
section { background: var(--surface-1); }

.section-header { max-width: 680px; }

.tech-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

/* ── Card ── */
.tech-card {
  position: relative;
  background: var(--surface-glass);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: transform var(--t-base) var(--ease-out),
              box-shadow var(--t-base),
              border-color var(--t-base);
}
.tech-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
  border-color: var(--border-2);
}
.tech-card:hover .card-border-glow { opacity: 1; }
.tech-card:hover .card-img-wrap img { transform: scale(1.04); }

/* ── Image ── */
.card-img-wrap { position: relative; overflow: hidden; height: 200px; }
.card-img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
  transition: transform var(--t-slow) var(--ease-out);
}
.card-img-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, transparent 40%, var(--surface-2) 100%);
}

/* ── Body ── */
.tech-card-body { padding: 22px 24px 28px; }
.card-icon-wrap {
  width: 44px; height: 44px;
  border-radius: var(--r-sm);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 14px;
}
.tech-card-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.05rem; font-weight: 700;
  color: var(--text); margin-bottom: 10px;
  line-height: 1.3;
}
.tech-card-text { font-size: 0.88rem; color: var(--text-2); line-height: 1.75; }

/* ── Bottom glow line on hover ── */
.card-border-glow {
  position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--glow), transparent);
  opacity: 0;
  transition: opacity var(--t-base);
}

/* ── Responsive ── */
@media (max-width: 960px)  { .tech-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px)  { .tech-grid { grid-template-columns: 1fr; } }
</style>
