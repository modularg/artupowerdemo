---
const apps = [
  { img: 'https://www.artupower.eu/wp-content/uploads/1.png', en: 'Passenger Vehicles',          lv: 'Vieglās Automašīnas',       href: 'https://www.artupower.eu/passenger-vehicles/' },
  { img: 'https://www.artupower.eu/wp-content/uploads/2.png', en: 'Light Duty Vehicles',         lv: 'Vieglie Kravas Transp.',     href: 'https://www.artupower.eu/light-duty-vehicles/' },
  { img: 'https://www.artupower.eu/wp-content/uploads/3.png', en: 'Buses',                       lv: 'Autobusi',                  href: 'https://www.artupower.eu/buses/' },
  { img: 'https://www.artupower.eu/wp-content/uploads/4.png', en: 'Heavy Duty Vehicles',         lv: 'Smagie Kravas Transp.',      href: 'https://www.artupower.eu/heavy-duty-vehicles/' },
  { img: 'https://www.artupower.eu/wp-content/uploads/5.png', en: 'Agricultural & Construction', lv: 'Lauksaim. un Celtniec.',     href: 'https://www.artupower.eu/agricultural-construction-vehicles/' },
  { img: 'https://www.artupower.eu/wp-content/uploads/6.png', en: 'Diesel Generators',           lv: 'Dīzeļgeneratori',            href: 'https://www.artupower.eu/diesel-generators/' },
  { img: 'https://www.artupower.eu/wp-content/uploads/7.png', en: 'Maritime',                    lv: 'Jūras Transp.',              href: 'https://www.artupower.eu/maritime/' },
];
---
<section id="applications" class="apps-section">
  <div class="section-inner">
    <div class="section-header reveal">
      <span class="section-tag" data-en="Use Cases" data-lv="Pielietojuma Gadījumi">Use Cases</span>
      <h2 class="section-title" data-en="Applications &amp; Use Cases" data-lv="Pielietojumi un Lietošanas Gadījumi">Applications &amp; Use Cases</h2>
      <div class="underline-accent"></div>
      <p
        class="section-lead"
        data-en="ArtuPower systems are engineered for a wide range of engine-powered applications, from city cars to maritime vessels."
        data-lv="ArtuPower sistēmas ir konstruētas plašam ar dzinēju darbināmu lietojumu klāstam — no pilsētas automobiļiem līdz jūras kuģiem."
      >
        ArtuPower systems are engineered for a wide range of engine-powered applications, from city cars to maritime vessels.
      </p>
    </div>

    <div class="apps-grid">
      {apps.map((a, i) => (
        <a
          href={a.href}
          target="_blank"
          rel="noopener noreferrer"
          class={`app-item reveal reveal-delay-${Math.min(i + 1, 6)}`}
          aria-label={a.en}
        >
          <div class="app-icon-wrap" aria-hidden="true">
            <img src={a.img} alt="" loading="lazy" width="80" height="60" />
          </div>
          <div class="app-label" data-en={a.en} data-lv={a.lv}>{a.en}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.apps-section { background: var(--surface-1); }
.section-header { max-width: 640px; }

.apps-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 12px;
}

/* ── App item ── */
.app-item {
  display: flex; flex-direction: column; align-items: center; gap: 12px;
  padding: 20px 10px;
  background: var(--surface-glass);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  text-decoration: none;
  position: relative;
  overflow: hidden;
  transition: background var(--t-base), border-color var(--t-base),
              transform var(--t-base) var(--ease-out), box-shadow var(--t-base);
}
/* Radial glow that fades in on hover */
.app-item::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 80% at 50% 60%, rgba(9,159,220,0.18) 0%, transparent 70%);
  opacity: 0;
  transition: opacity var(--t-base);
}
.app-item:hover::before { opacity: 1; }

.app-item:hover {
  background: rgba(9,159,220,0.1);
  border-color: rgba(9,159,220,0.55);
  transform: translateY(-8px) scale(1.03);
  box-shadow: 0 0 0 1px rgba(9,159,220,0.3),
              0 0 24px rgba(9,159,220,0.35),
              0 16px 40px rgba(0,0,0,0.5);
}
.app-item:active { transform: scale(0.97) translateY(-2px); }
.app-item:focus-visible {
  outline: 2px solid var(--blue); outline-offset: 3px;
}

.app-icon-wrap {
  width: 72px; height: 56px;
  display: flex; align-items: center; justify-content: center;
  position: relative;
  z-index: 1;
  transition: transform var(--t-base) var(--ease-spring);
}
/* Glowing halo behind the icon */
.app-icon-wrap::after {
  content: '';
  position: absolute; inset: -8px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(9,159,220,0.5) 0%, transparent 70%);
  opacity: 0;
  transform: scale(0.6);
  transition: opacity var(--t-base), transform var(--t-base) var(--ease-spring);
  filter: blur(6px);
}
.app-item:hover .app-icon-wrap {
  transform: scale(1.25) translateY(-4px);
}
.app-item:hover .app-icon-wrap::after {
  opacity: 1;
  transform: scale(1);
}

.app-icon-wrap img {
  width: 100%; height: 100%;
  object-fit: contain;
  filter: brightness(0) invert(1);
  opacity: 0.5;
  transition: opacity var(--t-base), filter var(--t-base) var(--ease-out),
              drop-shadow var(--t-base);
  position: relative; z-index: 1;
}
.app-item:hover .app-icon-wrap img {
  opacity: 1;
  filter: brightness(0) invert(1) sepia(1) hue-rotate(170deg) saturate(3)
          drop-shadow(0 0 8px rgba(11,191,255,0.9));
}

.app-label {
  font-size: 0.74rem; font-weight: 600;
  color: var(--text-2); text-align: center; line-height: 1.3;
  position: relative; z-index: 1;
  transition: color var(--t-base);
}
.app-item:hover .app-label { color: var(--blue2); }

/* ── Responsive ── */
@media (max-width: 1100px) { .apps-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 600px)  { .apps-grid { grid-template-columns: repeat(4, 1fr); gap: 8px; } }
@media (max-width: 400px)  { .apps-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
