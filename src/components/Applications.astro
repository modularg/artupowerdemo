---
const apps = [
  { img: 'https://www.artupower.eu/wp-content/uploads/1.png', en: 'Passenger Vehicles',          lv: 'Vieglās Automašīnas' },
  { img: 'https://www.artupower.eu/wp-content/uploads/2.png', en: 'Light Duty Vehicles',         lv: 'Vieglie Kravas Transport.' },
  { img: 'https://www.artupower.eu/wp-content/uploads/3.png', en: 'Buses',                       lv: 'Autobusi' },
  { img: 'https://www.artupower.eu/wp-content/uploads/4.png', en: 'Heavy Duty Vehicles',         lv: 'Smagie Kravas Transport.' },
  { img: 'https://www.artupower.eu/wp-content/uploads/5.png', en: 'Agricultural & Construction', lv: 'Lauksaim. un Celtniec.' },
  { img: 'https://www.artupower.eu/wp-content/uploads/6.png', en: 'Diesel Generators',           lv: 'Dīzeļgeneratori' },
  { img: 'https://www.artupower.eu/wp-content/uploads/7.png', en: 'Maritime',                    lv: 'Jūras Transport.' },
];
---
<section id="applications" class="apps-section">
  <div class="section-inner">
    <span class="section-tag" data-en="Use Cases" data-lv="Pielietojuma Gadījumi">Use Cases</span>
    <h2
      class="section-title light"
      data-en="Applications &amp; Use Cases"
      data-lv="Pielietojumi un Lietošanas Gadījumi"
    >
      Applications &amp; Use Cases
    </h2>
    <div class="underline-accent"></div>
    <p
      class="section-lead light"
      data-en="ArtuPower systems are engineered for a wide range of engine-powered applications, from city cars to maritime vessels."
      data-lv="ArtuPower sistēmas ir konstruētas plašam ar dzinēju darbināmu lietojumu klāstam — no pilsētas automobiļiem līdz jūras kuģiem."
    >
      ArtuPower systems are engineered for a wide range of engine-powered applications, from city cars to maritime vessels.
    </p>

    <div class="apps-grid">
      {apps.map(a => (
        <div class="app-item">
          <div class="app-img-wrap">
            <img src={a.img} alt={a.en} loading="lazy" />
          </div>
          <div class="app-label" data-en={a.en} data-lv={a.lv}>{a.en}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.apps-section { background: var(--navy2); }
.apps-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 14px; }

.app-item { text-align: center; }
.app-img-wrap {
  background: rgba(255,255,255,0.05);
  border-radius: 10px; padding: 20px; margin-bottom: 12px;
  border: 1px solid rgba(255,255,255,0.07);
  transition: background .2s, border-color .2s;
}
.app-item:hover .app-img-wrap {
  background: rgba(9,159,220,0.12);
  border-color: var(--blue);
}
.app-img-wrap img {
  width: 100%; max-width: 80px; height: 60px;
  object-fit: contain; display: block; margin: 0 auto;
  filter: brightness(0) invert(1); opacity: 0.75;
  transition: opacity .2s;
}
.app-item:hover .app-img-wrap img { opacity: 1; }
.app-label {
  font-size: 0.78rem; color: rgba(255,255,255,0.65);
  font-weight: 600; line-height: 1.3;
}

@media (max-width: 1100px) { .apps-grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 600px)  { .apps-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
