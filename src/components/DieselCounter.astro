---
---
<div class="counter-section">
  <div class="counter-inner section-inner">

    <!-- Live session counter — highlighted -->
    <div class="counter-card hero-card reveal">
      <div class="card-glow"></div>
      <div class="card-icon fuel-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 22V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v16"/><path d="M3 11h11M13 8.5l3 3 3-3M16 11.5V18a2 2 0 0 0 4 0v-5.5"/></svg>
      </div>
      <div class="card-value" aria-live="polite" aria-label="Live diesel savings counter">
        <span id="diesel-counter" class="tabular">0.0</span>
        <span class="card-unit">L</span>
      </div>
      <div class="card-label" id="diesel-label">
        Estimated diesel savings since you've been on this page
      </div>
      <div class="progress-bar" aria-hidden="true">
        <div class="progress-fill" id="progressFill"></div>
      </div>
    </div>

    <!-- CO₂ saved -->
    <div class="counter-card reveal reveal-delay-1">
      <div class="card-icon co2-icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M8 12s1-4 4-4 4 4 4 4"/><path d="M8 16h8"/></svg>
      </div>
      <div class="card-value" aria-live="polite">
        <span id="co2-counter" class="tabular">0.0</span>
        <span class="card-unit">kg CO₂</span>
      </div>
      <div class="card-label" data-en="Estimated CO₂ not emitted this session" data-lv="Aprēķinātais CO₂, kas nav emitēts šajā sesijā">
        Estimated CO₂ not emitted this session
      </div>
    </div>

    <!-- Diesel reduction -->
    <div class="counter-card reveal reveal-delay-2">
      <div class="card-icon reduction-icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
      </div>
      <div class="card-value">
        50<span class="card-unit">%</span>
      </div>
      <div class="card-label" data-en="Max diesel reduction per vehicle" data-lv="Maks. dīzeļa samazinājums vienam transportlīdzeklim">
        Max diesel reduction per vehicle
      </div>
    </div>

    <!-- Engine size -->
    <div class="counter-card reveal reveal-delay-3">
      <div class="card-icon engine-icon" aria-hidden="true">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2M12 12v3M8 12v3M16 12v3"/></svg>
      </div>
      <div class="card-value">
        18<span class="card-unit">L</span>
      </div>
      <div class="card-label" data-en="Max engine displacement supported" data-lv="Maks. atbalstītais motora tilpums">
        Max engine displacement supported
      </div>
    </div>

  </div>
</div>

<style>
.counter-section {
  background: var(--surface-2);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 40px;
}
.counter-inner {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1fr;
  gap: 16px;
}

/* ── Base card ── */
.counter-card {
  position: relative;
  background: var(--surface-glass);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: 28px 24px;
  overflow: hidden;
  transition: border-color var(--t-base), transform var(--t-base) var(--ease-out),
              box-shadow var(--t-base);
}
.counter-card:hover {
  border-color: var(--border-2);
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
}

/* ── Hero (live counter) card ── */
.hero-card {
  background: linear-gradient(135deg, rgba(9,159,220,0.14) 0%, rgba(9,159,220,0.06) 100%);
  border-color: rgba(9,159,220,0.3);
}
.hero-card:hover {
  border-color: rgba(9,159,220,0.5);
  box-shadow: var(--glow-blue), var(--shadow-md);
}
.card-glow {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(9,159,220,0.15), transparent 70%);
  pointer-events: none;
}

/* ── Card icons ── */
.card-icon {
  width: 48px; height: 48px;
  border-radius: var(--r-md);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 14px;
}
.fuel-icon      { background: rgba(9,159,220,0.15); color: var(--blue2); }
.co2-icon       { background: rgba(58,172,93,0.12); color: var(--green2); }
.reduction-icon { background: rgba(255,165,0,0.1);  color: #ffa500; }
.engine-icon    { background: rgba(255,255,255,0.06); color: var(--text-2); }

/* ── Values ── */
.card-value {
  display: flex; align-items: baseline; gap: 4px;
  margin-bottom: 8px;
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(2rem, 3.5vw, 2.8rem);
  font-weight: 700; color: #fff; line-height: 1;
}
.card-unit {
  font-size: 0.45em; font-weight: 600;
  color: var(--text-2); margin-left: 2px;
}
.tabular { font-variant-numeric: tabular-nums; }

/* ── Label ── */
.card-label {
  font-size: 0.78rem; color: var(--text-2);
  font-weight: 500; line-height: 1.45;
}
.hero-card .card-value { color: var(--blue2); }
.hero-card .card-label { color: rgba(255,255,255,0.65); }

/* ── Progress bar ── */
.progress-bar {
  position: absolute; bottom: 0; left: 0; right: 0;
  height: 3px; background: rgba(9,159,220,0.1);
  border-radius: 0 0 var(--r-lg) var(--r-lg);
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: var(--grad-blue);
  width: 0%;
  transition: width 0.1s linear;
  box-shadow: 0 0 8px rgba(9,159,220,0.6);
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .counter-inner { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 600px)  {
  .counter-section { padding: 24px 16px; }
  .counter-inner { grid-template-columns: 1fr 1fr; gap: 10px; }
  .counter-card { padding: 20px 16px; }
  .card-icon { width: 38px; height: 38px; }
}
</style>

<script>
  // 200 trucks × 8 L/h each = 1,600 L/h = 0.4444 L/s
  const DIESEL_RATE   = 0.4444;
  const CO2_PER_LITRE = 2.65;
  // Progress bar cycles every 60s
  const CYCLE_S       = 60;

  const startTime = Date.now();
  const dieselEl  = document.getElementById('diesel-counter')!;
  const co2El     = document.getElementById('co2-counter')!;
  const fillEl    = document.getElementById('progressFill')!;

  function tick() {
    const elapsed = (Date.now() - startTime) / 1000;
    const litres  = elapsed * DIESEL_RATE;
    dieselEl.textContent = litres.toFixed(1);
    co2El.textContent    = (litres * CO2_PER_LITRE).toFixed(1);
    // Progress bar: cycles through 0–100% every CYCLE_S seconds
    const pct = ((elapsed % CYCLE_S) / CYCLE_S) * 100;
    fillEl.style.width = pct + '%';
  }
  setInterval(tick, 100);
</script>
