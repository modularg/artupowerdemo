---
---
<section class="hero" aria-label="Hero">
  <!-- Layered background -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-img"></div>
    <div class="hero-overlay"></div>
    <div class="hero-mesh"></div>
  </div>

  <!-- Floating stat chips -->
  <div class="hero-stat-chips" aria-hidden="true">
    <div class="stat-chip chip-1">
      <span class="chip-num">50%</span>
      <span class="chip-label" data-en="less diesel" data-lv="mazāk dīzeļa">less diesel</span>
    </div>
    <div class="stat-chip chip-2">
      <span class="chip-num">18L</span>
      <span class="chip-label" data-en="max engine" data-lv="maks. dzinējs">max engine</span>
    </div>
    <div class="stat-chip chip-3">
      <span class="chip-num">4</span>
      <span class="chip-label" data-en="fuel types" data-lv="degvielas veidi">fuel types</span>
    </div>
  </div>

  <div class="hero-content">
    <div class="hero-badge reveal" data-en="Cleantech Innovation" data-lv="Tīro tehnoloģiju inovācija">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--blue2)" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
      Cleantech Innovation
    </div>

    <h1 class="hero-title reveal reveal-delay-1">
      <span class="title-line" data-en="Alternative Fuel" data-lv="Alternatīvā Degviela">Alternative Fuel</span>
      <span class="title-line" data-en="Solutions for" data-lv="Risinājumi">Solutions for</span>
      <span class="title-line gradient-text" data-en="Low-Emission Mobility" data-lv="Zemu Emisiju Mobilitātei">Low-Emission Mobility</span>
    </h1>

    <p
      class="hero-subtitle reveal reveal-delay-2"
      data-en="ArtuPower enables diesel engines to run on cleaner alkane gas blends — reducing diesel consumption by up to 50% without replacing your existing fleet."
      data-lv="ArtuPower ļauj dīzeļdzinējiem darboties ar tīrākām alkāna gāzes maisījumiem — samazinot dīzeļa patēriņu par līdz 50%, neaizstājot esošo autoparka tehniku."
    >
      ArtuPower enables diesel engines to run on cleaner alkane gas blends — reducing diesel consumption by up to 50% without replacing your existing fleet.
    </p>

    <div class="hero-actions reveal reveal-delay-3">
      <a href="#products" class="btn-primary">
        <span data-en="Explore Products" data-lv="Apskatīt Produktus">Explore Products</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="#mission" class="btn-outline">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
        <span data-en="Watch Video" data-lv="Skatīt Video">Watch Video</span>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-hint reveal reveal-delay-4" aria-hidden="true">
      <div class="scroll-dot"></div>
      <span data-en="Scroll to explore" data-lv="Ritiniet, lai izpētītu">Scroll to explore</span>
    </div>
  </div>
</section>

<style>
/* ── Hero shell ── */
.hero {
  position: relative;
  min-height: 70dvh;
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* ── Background layers ── */
.hero-bg { position: absolute; inset: 0; }

/* Dark base + dot-grid texture */
.hero-img {
  position: absolute; inset: 0;
  background-color: #070f1a;
  background-image:
    radial-gradient(circle, rgba(255,255,255,0.06) 1px, transparent 1px);
  background-size: 36px 36px;
}

/* Diagonal light-streak overlay */
.hero-overlay {
  position: absolute; inset: 0;
  background:
    linear-gradient(118deg,
      rgba(9,159,220,0.18) 0%,
      transparent 35%,
      transparent 65%,
      rgba(58,172,93,0.10) 100%),
    linear-gradient(to bottom, transparent 50%, rgba(7,15,26,0.95) 100%),
    linear-gradient(to right, rgba(7,15,26,0.6) 0%, transparent 60%);
}

/* Animated gradient orbs */
.hero-mesh {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 55% 60% at 72% 38%, rgba(9,159,220,0.22) 0%, transparent 65%),
    radial-gradient(ellipse 40% 50% at 15% 75%, rgba(58,172,93,0.16) 0%, transparent 60%),
    radial-gradient(ellipse 30% 40% at 85% 80%, rgba(11,191,255,0.10) 0%, transparent 60%);
  animation: meshFloat 10s ease-in-out infinite alternate;
}
@keyframes meshFloat {
  from { opacity: 0.7; transform: scale(1) translateY(0); }
  to   { opacity: 1;   transform: scale(1.05) translateY(-8px); }
}

/* ── Floating stat chips ── */
.hero-stat-chips {
  position: absolute;
  right: max(60px, 8vw);
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 14px;
  z-index: 2;
}
.stat-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--r-lg);
  padding: 16px 22px;
  text-align: center;
  opacity: 0;
  transform: translateX(24px);
  animation: chipSlideIn 0.6s var(--ease-out) forwards;
}
.chip-1 { animation-delay: 0.8s; }
.chip-2 { animation-delay: 1.0s; }
.chip-3 { animation-delay: 1.2s; }
@keyframes chipSlideIn {
  to { opacity: 1; transform: none; }
}
.chip-num {
  font-family: 'Space Grotesk', sans-serif;
  font-size: 1.8rem; font-weight: 700; color: #fff; line-height: 1;
}
.chip-2 .chip-num { color: var(--blue2); }
.chip-3 .chip-num { color: var(--green2); }
.chip-label {
  font-size: 0.7rem; font-weight: 600; color: rgba(255,255,255,0.5);
  text-transform: uppercase; letter-spacing: 0.1em; margin-top: 4px;
}

/* ── Content ── */
.hero-content {
  position: relative; z-index: 1;
  padding: 110px 40px 56px;
  max-width: 760px;
}

.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(9,159,220,0.12);
  border: 1px solid rgba(9,159,220,0.3);
  color: var(--blue2);
  font-size: 0.74rem; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 7px 16px; border-radius: 100px;
  margin-bottom: 24px;
}
.hero-badge svg { flex-shrink: 0; animation: pulse 2.5s ease-in-out infinite; }
@keyframes pulse {
  0%, 100% { opacity: 0.6; transform: scale(1); }
  50%       { opacity: 1;   transform: scale(1.3); }
}

.hero-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(2.4rem, 6vw, 4.4rem);
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin-bottom: 24px;
  color: #fff;
}
.title-line { display: block; }
.gradient-text {
  background: var(--grad-hero);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  color: rgba(255,255,255,0.68);
  line-height: 1.78;
  max-width: 540px;
  margin-bottom: 40px;
}

.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 32px; }

/* ── Scroll hint ── */
.scroll-hint {
  display: flex; align-items: center; gap: 10px;
  color: rgba(255,255,255,0.35);
  font-size: 0.78rem; font-weight: 500; letter-spacing: 0.08em;
}
.scroll-dot {
  width: 24px; height: 38px;
  border: 2px solid rgba(255,255,255,0.2);
  border-radius: 12px;
  position: relative;
  flex-shrink: 0;
}
.scroll-dot::after {
  content: '';
  position: absolute; left: 50%; top: 6px;
  transform: translateX(-50%);
  width: 4px; height: 8px;
  background: rgba(255,255,255,0.5);
  border-radius: 2px;
  animation: scrollBob 2s ease-in-out infinite;
}
@keyframes scrollBob {
  0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
  80%       { transform: translateX(-50%) translateY(12px); opacity: 0; }
}

/* ── Responsive ── */
@media (max-width: 900px) {
  .hero-stat-chips { display: none; }
  .hero-content { padding: 96px 24px 48px; }
}
@media (max-width: 480px) {
  .hero-content { padding: 88px 16px 40px; }
  .scroll-hint { display: none; }
}
</style>
