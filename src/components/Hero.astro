---
---
<section class="hero" aria-label="Hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-img"></div>
    <div class="hero-overlay"></div>
    <div class="hero-mesh"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-kicker reveal" data-en="Cleantech Innovation" data-lv="Tiro tehnologiju inovacija">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="var(--blue2)" aria-hidden="true"><circle cx="12" cy="12" r="10"/></svg>
        Cleantech Innovation
      </div>

      <h1 class="hero-title reveal reveal-delay-1">
        <span class="title-line" data-en="Alternative Fuel" data-lv="Alternativa degviela">Alternative Fuel</span>
        <span class="title-line" data-en="Systems for" data-lv="Sistemas">Systems for</span>
        <span class="title-line gradient-text" data-en="Working Diesel Fleets" data-lv="Dizela autoparkiem">Working Diesel Fleets</span>
      </h1>

      <p
        class="hero-subtitle reveal reveal-delay-2"
        data-en="ArtuPower helps existing diesel engines run on cleaner alkane gas blends, reducing diesel consumption by up to 50% without replacing the vehicles already doing the work."
        data-lv="ArtuPower palidz esosiem dizeldzinejiem darboties ar tirakiem alkana gazes maisijumiem, samazinot dizela paterinu lidz 50%, neaizstajot esosus transportlidzeklus."
      >
        ArtuPower helps existing diesel engines run on cleaner alkane gas blends, reducing diesel consumption by up to 50% without replacing the vehicles already doing the work.
      </p>

      <div class="hero-actions reveal reveal-delay-3">
        <a href="#products" class="btn-primary">
          <span data-en="Explore Products" data-lv="Apskatit produktus">Explore Products</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="#mission" class="btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
          <span data-en="Watch Video" data-lv="Skatit video">Watch Video</span>
        </a>
      </div>

      <div class="hero-proof reveal reveal-delay-4" aria-label="Key ArtuPower figures">
        <div>
          <strong>50%</strong>
          <span data-en="diesel reduction" data-lv="dizela samazinajums">diesel reduction</span>
        </div>
        <div>
          <strong>18L</strong>
          <span data-en="engine support" data-lv="motora atbalsts">engine support</span>
        </div>
        <div>
          <strong>4</strong>
          <span data-en="fuel variants" data-lv="degvielas veidi">fuel variants</span>
        </div>
      </div>
    </div>

    <div class="hero-visual reveal reveal-right reveal-delay-2" aria-hidden="true">
      <div class="logo-glow"></div>
      <img
        src="https://www.artupower.eu/wp-content/uploads/cropped-ABLabs_logo_favicon-270x270.png"
        alt=""
        class="hero-logo"
        width="270" height="270"
      />
    </div>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: min(860px, 100svh);
  display: flex;
  align-items: center;
  overflow: clip;
  padding: 104px 40px 64px;
  isolation: isolate;
}

.hero-bg { position: absolute; inset: 0; }

.hero-img {
  position: absolute;
  inset: 0;
  background-color: #05080c;
  background-image:
    linear-gradient(90deg, rgba(255,255,255,0.045) 1px, transparent 1px),
    linear-gradient(0deg, rgba(255,255,255,0.035) 1px, transparent 1px),
    url('https://www.artupower.eu/wp-content/uploads/2022/06/service-2.jpg');
  background-size: 72px 72px, 72px 72px, cover;
  background-position: center, center, center;
  filter: saturate(0.72) contrast(1.08);
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(3,7,11,0.96) 0%, rgba(5,10,16,0.86) 42%, rgba(5,10,16,0.34) 100%),
    linear-gradient(180deg, rgba(3,7,11,0.48) 0%, rgba(3,7,11,0.7) 100%);
}

.hero-mesh {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(120deg, transparent 0 58%, rgba(28,105,212,0.28) 58.2%, transparent 59.4%),
    radial-gradient(ellipse 36% 44% at 78% 34%, rgba(9,159,220,0.2) 0%, transparent 72%);
}

.hero-inner {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 40px;
}

.hero-content {
  flex: 1;
  min-width: 0;
  max-width: 690px;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: rgba(255,255,255,0.74);
  font-size: 0.72rem;
  font-weight: 800;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 22px;
}
.hero-kicker svg { flex-shrink: 0; }

.hero-title {
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(2.7rem, 6.4vw, 5.8rem);
  font-weight: 500;
  line-height: 0.96;
  letter-spacing: 0;
  margin-bottom: 18px;
  color: #fff;
  text-transform: uppercase;
}
.title-line { display: block; }
.gradient-text {
  background: linear-gradient(90deg, #ffffff 0%, #8fd8ff 46%, #78d89a 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-subtitle {
  font-size: clamp(1rem, 1.45vw, 1.14rem);
  color: rgba(255,255,255,0.74);
  line-height: 1.62;
  max-width: 560px;
  margin-bottom: 28px;
}

.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}

.hero-proof {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1px;
  max-width: 560px;
  margin-top: 34px;
  border: 1px solid rgba(255,255,255,0.14);
  background: rgba(255,255,255,0.1);
}
.hero-proof div {
  background: rgba(3,7,11,0.54);
  padding: 18px 20px;
}
.hero-proof strong {
  display: block;
  color: #fff;
  font-family: 'Space Grotesk', sans-serif;
  font-size: clamp(1.35rem, 2.2vw, 2rem);
  line-height: 1;
  margin-bottom: 6px;
}
.hero-proof span {
  color: rgba(255,255,255,0.56);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.hero-visual {
  flex-shrink: 0;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: clamp(190px, 24vw, 320px);
  height: clamp(190px, 24vw, 320px);
  opacity: 0.82;
}

.logo-glow {
  position: absolute;
  inset: -30%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(9,159,220,0.28) 0%, transparent 65%);
  filter: blur(20px);
}

.hero-logo {
  position: relative;
  z-index: 1;
  width: 100%;
  height: auto;
  filter: drop-shadow(0 0 32px rgba(9,159,220,0.38));
  animation: logoFloat 7s ease-in-out infinite alternate;
}
@keyframes logoFloat {
  from { transform: translateY(0); }
  to { transform: translateY(-10px); }
}

@media (max-width: 900px) {
  .hero {
    min-height: auto;
    padding: 96px 24px 56px;
    align-items: flex-start;
  }
  .hero-inner {
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }
  .hero-visual { display: none; }
}
@media (max-width: 480px) {
  .hero { padding: 92px 16px 44px; }
  .hero-actions { flex-direction: column; align-items: stretch; }
  .hero-actions a { justify-content: center; }
  .hero-proof { grid-template-columns: 1fr; margin-top: 24px; }
}
</style>
