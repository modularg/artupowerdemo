<footer>
  <div class="footer-inner">
    <div class="footer-grid">

      <div class="footer-brand">
        <img
          src="https://www.artupower.eu/wp-content/uploads/artupower-logo-white-300x79.png"
          alt="ArtuPower"
          width="150" height="40"
        />
        <p
          data-en="Alternative fuel solutions for low-emission mobility. ABLabs Ltd, Jurkalnes 5, Jūrmala, Latvia."
          data-lv="Alternatīvās degvielas risinājumi zemu emisiju mobilitātei. SIA ABLabs, Jurkalnes 5, Jūrmala, Latvija."
        >
          Alternative fuel solutions for low-emission mobility. ABLabs Ltd, Jurkalnes 5, Jūrmala, Latvia.
        </p>
      </div>

      <div class="footer-col">
        <h4 data-en="Technology" data-lv="Tehnoloģija">Technology</h4>
        <ul>
          <li><a href="https://www.artupower.eu/technology/" target="_blank" data-en="How It Works"  data-lv="Kā tas darbojas">How It Works</a></li>
          <li><a href="https://www.artupower.eu/technology/" target="_blank" data-en="H₂O-CH System" data-lv="H₂O-CH Sistēma">H₂O-CH System</a></li>
          <li><a href="https://www.artupower.eu/technology/" target="_blank" data-en="EU Green Deal"  data-lv="ES Zaļais kurss">EU Green Deal</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 data-en="Products" data-lv="Produkti">Products</h4>
        <ul>
          <li><a href="https://www.artupower.eu/products/" target="_blank">3L / LPG / BioLPG</a></li>
          <li><a href="https://www.artupower.eu/products/" target="_blank">18L / LPG / BioCNG</a></li>
          <li><a href="https://www.artupower.eu/products/" target="_blank">18L / CNG / BioCNG</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4 data-en="Company" data-lv="Uzņēmums">Company</h4>
        <ul>
          <li><a href="https://www.artupower.eu/company/"                  target="_blank" data-en="About Us"          data-lv="Par mums">About Us</a></li>
          <li><a href="https://www.artupower.eu/news/"                     target="_blank" data-en="News"              data-lv="Ziņas">News</a></li>
          <li><a href="https://www.artupower.eu/faq/"                      target="_blank">FAQ</a></li>
          <li><a href="https://www.artupower.eu/become-business-partner/"  target="_blank" data-en="Become a Partner"  data-lv="Kļūt par Partneri">Become a Partner</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p
        data-en="© 2025 ABLabs Ltd. All rights reserved."
        data-lv="© 2025 SIA ABLabs. Visas tiesības aizsargātas."
      >© 2025 ABLabs Ltd. All rights reserved.</p>
      <p class="footer-contact">
        <a href="mailto:info@artupower.eu">info@artupower.eu</a>
        &nbsp;·&nbsp;
        <a href="tel:+37129214730">+371 29 214 730</a>
      </p>
    </div>
  </div>
</footer>

<style>
footer {
  background: #080f17;
  padding: 50px 40px 30px;
  border-top: 1px solid rgba(255,255,255,0.05);
}
.footer-inner { max-width: 1200px; margin: 0 auto; }
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 50px;
  margin-bottom: 40px;
}
.footer-brand img   { height: 36px; display: block; margin-bottom: 16px; }
.footer-brand p     { font-size: 0.88rem; color: rgba(255,255,255,0.4); line-height: 1.7; max-width: 280px; }

.footer-col h4 {
  color: #fff; font-size: 0.85rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 18px;
}
.footer-col ul        { list-style: none; }
.footer-col ul li     { margin-bottom: 10px; }
.footer-col ul li a   { color: rgba(255,255,255,0.42); font-size: 0.88rem; text-decoration: none; transition: color .2s; }
.footer-col ul li a:hover { color: var(--blue); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.06);
  padding-top: 24px;
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 12px;
}
.footer-bottom p       { font-size: 0.82rem; color: rgba(255,255,255,0.28); }
.footer-contact a      { color: var(--blue); text-decoration: none; }

@media (max-width: 1100px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
@media (max-width: 600px)  { .footer-grid { grid-template-columns: 1fr; gap: 28px; } }
</style>
