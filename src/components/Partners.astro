---
const partners = [
  { src: 'https://www.artupower.eu/wp-content/uploads/Magnetic_logo2.png',                                   alt: 'Magnetic' },
  { src: 'https://www.artupower.eu/wp-content/uploads/Green-Tech-Cluster-logo-B-transp-e1508746380971.png', alt: 'Green Tech Cluster' },
  { src: 'https://www.artupower.eu/wp-content/uploads/Liepaja-University_FSE-e1613323356586.png',           alt: 'Liepāja University FSE' },
  { src: 'https://www.artupower.eu/wp-content/uploads/rtu_logo.png',                                        alt: 'RTU – Riga Technical University' },
  { src: 'https://www.artupower.eu/wp-content/uploads/norsk-energy.png',                                    alt: 'Norsk Energi' },
  { src: 'https://www.artupower.eu/wp-content/uploads/cr-logo-full.png',                                    alt: 'Cleantech Rising' },
];
---
<section id="partners" class="partners-section">
  <div class="section-inner">
    <div class="section-header reveal">
      <span class="section-tag" data-en="Ecosystem" data-lv="Ekosistēma">Ecosystem</span>
      <h2 class="section-title" data-en="Partners &amp; Collaborators" data-lv="Partneri un Sadarbības Partneri">Partners &amp; Collaborators</h2>
      <div class="underline-accent"></div>
      <p
        class="section-lead"
        data-en="ArtuPower is supported by a network of investors, research institutions, and cleantech organisations across Latvia and Europe."
        data-lv="ArtuPower atbalsta investoru, pētniecības iestāžu un tīro tehnoloģiju organizāciju tīkls Latvijā un Eiropā."
      >
        ArtuPower is supported by a network of investors, research institutions, and cleantech organisations across Latvia and Europe.
      </p>
    </div>

    <div class="partners-grid">
      {partners.map((p, i) => (
        <div class={`partner-card reveal reveal-delay-${Math.min(i + 1, 5)}`}>
          <div class="partner-inner">
            <img src={p.src} alt={p.alt} loading="lazy" />
          </div>
          <div class="partner-name" aria-hidden="true">{p.alt}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.partners-section { background: var(--surface-1); }
.section-header { max-width: 640px; }

.partners-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* ── Card ── */
.partner-card {
  background: var(--surface-glass);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  overflow: hidden;
  transition: border-color var(--t-base), transform var(--t-base) var(--ease-out),
              box-shadow var(--t-base);
}
.partner-card:hover {
  border-color: var(--border-blue);
  transform: translateY(-4px);
  box-shadow: var(--glow-blue), var(--shadow-md);
}

.partner-inner {
  padding: 32px 36px;
  display: flex; align-items: center; justify-content: center;
  min-height: 100px;
}
.partner-inner img {
  max-height: 52px; max-width: 180px;
  object-fit: contain; display: block;
  filter: brightness(0) invert(1);
  opacity: 0.55;
  transition: opacity var(--t-base), filter var(--t-base);
}
.partner-card:hover .partner-inner img {
  opacity: 1;
  filter: brightness(0) invert(1);
}

.partner-name {
  padding: 10px 18px 14px;
  font-size: 0.76rem; font-weight: 600;
  color: var(--text-3); text-align: center;
  border-top: 1px solid var(--border);
  transition: color var(--t-base);
}
.partner-card:hover .partner-name { color: var(--blue2); }

/* ── Responsive ── */
@media (max-width: 860px) { .partners-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 500px) { .partners-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; } }
</style>
