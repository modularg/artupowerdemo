---
import Layout        from '../layouts/Layout.astro';
import Nav           from '../components/Nav.astro';
import Hero          from '../components/Hero.astro';
import DieselCounter from '../components/DieselCounter.astro';
import Technology    from '../components/Technology.astro';
import Products      from '../components/Products.astro';
import Applications  from '../components/Applications.astro';
import Mission       from '../components/Mission.astro';
import Partners      from '../components/Partners.astro';
import Grants        from '../components/Grants.astro';
import Footer        from '../components/Footer.astro';
---
<Layout>
  <Nav />
  <Hero />
  <DieselCounter />
  <Technology />
  <Products />
  <Applications />
  <Mission />
  <Partners />
  <Grants />
  <Footer />
</Layout>

<script>
  import { initI18n } from '../scripts/i18n';
  // Run after DOM is ready (Astro defers scripts automatically)
  initI18n();
</script>
